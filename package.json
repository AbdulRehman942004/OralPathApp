{
  "name": "oralpath-learn",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Interactive Educational Application in Odontogenic Oral Pathology",
  "scripts": {
    "dev": "esbuild src/main.jsx --bundle --outfile=dist/bundle.js --format=esm --loader:.js=jsx --jsx=automatic --servedir=. --serve=0.0.0.0:5173",
    "build": "esbuild src/main.jsx --bundle --outfile=dist/bundle.js --format=esm --loader:.js=jsx --jsx=automatic --minify --define:process.env.NODE_ENV=\\\"production\\\"",
    "start": "python3 -m http.server 5173"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.21.5"
  }
}
